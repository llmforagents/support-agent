{
  "name": "support-llm4agents",
  "version": "0.5.2",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r --parallel build",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "pnpm -r --parallel lint",
    "test": "pnpm -r run test",
    "test:ci": "pnpm -r run test:ci",
    "test:integration": "pnpm --filter backend run test:integration",
    "audit": "pnpm typecheck && pnpm lint && pnpm test:ci && pnpm build && pnpm test:integration && pnpm --filter backend run test:cf && pnpm --filter backend run build:cf",
    "dev:backend": "pnpm --filter backend dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:widget": "pnpm --filter widget dev",
    "dev:test": "concurrently -k -n backend,admin,widget -c blue,green,yellow \"pnpm dev:backend\" \"pnpm dev:admin\" \"pnpm dev:widget\"",
    "test:e2e": "pnpm --filter e2e run test"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "tar": "^7.5.4"
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3"
  }
}
