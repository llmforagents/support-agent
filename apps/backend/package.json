{
  "name": "backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --target node20 --clean",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests --max-warnings 0",
    "test": "vitest",
    "test:ci": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run integration",
    "test:cf": "vitest run --config tests/cloudflare/vitest.config.ts",
    "build:cf": "wrangler deploy --dry-run --outdir dist-cf"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@llmforagents/sdk": "^2.3.2",
    "@support/shared": "workspace:*",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "chardet": "^2.1.0",
    "gpt-tokenizer": "^2.5.0",
    "hono": "^4.6.0",
    "mdast-util-to-string": "^4.0.0",
    "mysql2": "^3.11.4",
    "node-sql-parser": "^5.3.13",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "remark-parse": "^11.0.0",
    "ulid": "^2.3.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.3",
    "@cloudflare/workers-types": "4.20260511.1",
    "@testcontainers/postgresql": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/mdast": "^4.0.0",
    "@types/node": "^22.19.19",
    "@types/pg": "^8.11.10",
    "pdf-lib": "^1.17.1",
    "pino-pretty": "^11.2.2",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.0",
    "wrangler": "4.90.0"
  }
}
