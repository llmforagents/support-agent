{
  "name": "widget",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "build": "vite build --config vite.config.ts && vite build --config vite.bootstrap.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest",
    "test:ci": "vitest run"
  },
  "dependencies": {
    "preact": "^10.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.8.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^22.0.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
