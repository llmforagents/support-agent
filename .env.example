# ====================================================================
#  REQUIRED SECRETS — generate with: node scripts/init-env.mjs
# ====================================================================

# 64 hex chars. Encrypts the llm4agents API key in the database.
# WARNING: rotating this key requires re-running onboarding.
ENCRYPTION_KEY=

# 64 hex chars. Signs short-lived SSE stream tokens.
STREAM_TOKEN_SECRET=

# ≥32 chars. Signs the admin session cookie.
COOKIE_SECRET=

# Postgres password. MUST be a strong unique value. NO default.
POSTGRES_PASSWORD=

# ====================================================================
#  REQUIRED URLS
# ====================================================================

PUBLIC_API_URL=http://localhost:3001
ADMIN_ORIGIN=http://localhost:3000

# ====================================================================
#  OPTIONAL TUNABLES
# ====================================================================

LLM4AGENTS_API_BASE=https://api.llm4agents.com
COOKIE_SECURE=true
LOG_LEVEL=info
MAX_BODY_BYTES=65536
SSE_MAX_CONNECTIONS=2000
SSE_MAX_LIFETIME_MS=14400000
